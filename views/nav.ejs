<!doctype html>
<html lang="en" dir="ltr">
 <head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
  <title>Career Portal</title>
 </head>
 <body>
  <nav class="navbar navbar-expand-lg">
   <div class="container-fluid px-3">
    <a class="navbar-brand" href="/">Career Portal</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-body" aria-controls="navbar-body" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbar-body">
     <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
      <li class="nav-item"><a class="nav-link <%= req.path === '/' ? 'active' : '' %>" href="/">Shifts</a></li>
      <li class="nav-item"><a class="nav-link <%= req.path === '/tasks' ? 'active' : '' %>" href="/tasks">Tasks</a></li>
      <li class="nav-item"><a class="nav-link <%= req.path === '/user' ? 'active' : '' %>" href="/user">User</a></li>
      <li class="nav-item nav-divider"></li>
      <% if (req.session && req.session.user) { %>
      <li class="nav-item">
        <a class="nav-link nav-user-chip" href="/user">
          <%= req.session.user.first_name %> <%= req.session.user.last_name %>
        </a>
      </li>
      <% } %>
      <li class="nav-item"><a class="nav-link nav-logout" href="/logout">Sign Out</a></li>
     </ul>
    </div>
   </div>
  </nav>
  <div class="container-fluid" id="bsr-wrapper"></div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
 </body>
</html>