<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/assets/style.css" type="text/css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
</head>
<body id="main-body">

    <div id="pseudo-body">
        
        <%- include('nav'); -%>


        <div id="user_body_container" class="centered_item">
            
            <div class="" id="user_details">
                <p>User Name: <%=req.session.user.first_name + " " + req.session.user.last_name%></p>
                <p>User Email: <%= req.session.user.email%></p>
                <p>User netid: <%= req.session.user.netid %></p>

                <% if (req.session.user.role === "admin"){ %>
                    <p>Role: Admin</p>
                    <button type="button" id="add_user" >Add User</button>
                    <button type="button" id="show_all_users">See Users</button>
                <%}else if (req.session.user.role === "sub_admin") {%>
                    <p>Role: Career Advisor</p>
                <%}else {%>
                    <p>Role: Career Assistant</p>
                <%}%>
            </div>

            <div class="hidden_task" id="adduser_form_container">
                <form action="/user/add_role" method="POST" class="" id="add_form">
                    <label for="first_name">New user's first name: </label>
                    <input type="text" name="first_name" id="first_name">
    
                    <br>
    
                    <label for="last_name">New user's last name: </label>
                    <input type="text" name="last_name" id="last_name">
    
                    <br>
    
                    <label for="email">New user's email: </label>
                    <input type="email" name="email" id="email">
    
                    <br>
    
                    <label for="netid">New user's netid: </label>
                    <input type="text" name="netid" id="netid">
    
                    <br>
    
                    <label for="role">Choose new user's role: </label>
                    <select name="role" id="role">
                        <option value="admin">Administer</option>
                        <option value="sub_admin">Career Advisor</option>
                        <option value="ca">Career Assistant</option>
                    </select>
    
                    <br>
                    
                    <label for="password">New user's password: </label>
                    <input type="text" name="password" id="password">

                    <br>
                    <button type="submit" id="submit_user">Add User</button>
                    <button type="button" id="cancel_adding_user">Cancel</button>
    
                </form>
            </div>

            <div id="users_display_container" class="hidden_task">
                <button type="button" id="back_to_user_profile">Go back to your profile</button>
                <div class="position-relative">
                    <input id="search_user" type="text" class="form-control" placeholder="Search by name">
                    <ul id="search_results" class="list-group position-absolute w-100" class="hidden_task"></ul>

                </div>
                

                <table class="table table-striped " id="users_info_table">
                    <tr>
                        <th>User Name</th> <th>User email</th> <th>User role</th>
                    </tr>
                    <% user.forEach((usr)=>{ %>
                            <tr class="user_info_row" data-user-email="<%= usr.email %>">
                                <td><%= usr.first_name + " " + usr.last_name %></td>
                                <td><%= usr.email %></td>
                                <td>
                                    <% if (usr.role === "ca") { %>
                                    Career Assistant
                                    <% } else if (usr.role === "admin") { %>
                                    Administer
                                    <% } else if (usr.role === "sub_admin") { %>
                                    Career Advisor
                                    <% } %>
                                </td>
                                
                            </tr>
                    <%})%>
                </table>
            </div>
        </div>

    </div>

    

    <script src="/assets/admin_user_script.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
</body>
</html>